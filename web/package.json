    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.0",
