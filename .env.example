# SoulGraph Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Required
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — infrastructure (defaults work with docker compose up)
REDIS_URL=redis://localhost:6379
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Optional — logging
SOULGRAPH_LOG_LEVEL=INFO

# Phase 2 — Model Router (LiteLLM)
LITELLM_REASONING_MODEL=claude-3-5-haiku-20241022
LITELLM_FAST_MODEL=claude-3-5-haiku-20241022

# Phase 2 — LangSmith (managed cloud tracing)
# Get your key from https://smith.langchain.com — free tier available
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=soulgraph-dev

# Phase 2 — LangFuse (self-hosted tracing, started via docker compose)
# After running: docker compose up -d langfuse
# Open http://localhost:3100, create project, copy keys here
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Phase 2 — API server
SOULGRAPH_API_HOST=0.0.0.0
SOULGRAPH_API_PORT=8080
